{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/logos.schema.json",
  "title": "Logos Data Schema",
  "description": "Esquema de validación para logos.json - API estática de logos para generador de QR",
  "type": "object",
  "properties": {
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Lista de categorías disponibles"
    },
    "logos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2,
            "description": "Identificador único del logo (slug)"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "description": "Nombre visible del logo"
          },
          "category": {
            "type": "string",
            "description": "Categoría a la que pertenece el logo"
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$",
            "description": "Color principal en formato hex (#RRGGBB)"
          },
          "imageUrl": {
            "type": "string",
            "description": "URL del SVG. Puede ser CDN externa o ruta local (svg/nombre.svg)"
          },
          "localSvg": {
            "type": "boolean",
            "description": "Indica si el SVG está alojado localmente en la carpeta /svg/"
          }
        },
        "required": ["id", "name", "category", "color", "imageUrl"],
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "required": ["categories", "logos"],
  "additionalProperties": false
}
